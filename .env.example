# Скопируй в .env на сервере и заполни значения

POSTGRES_USER=pulse
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cardio_marathon
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Обязателен для JWT-авторизации
SECRET_KEY=change_me_to_a_long_random_string

# OCR (OpenRouter), опционально
OPENROUTER_API_KEY=

# 1 = дропнуть таблицы при старте backend (только для миграции схемы)
RESET_DB=0
